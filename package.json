{
  "name": "@saali2901/sa-ui",
  "description": "Vue.js free to use UI-Library",
  "keywords": [
    "UI",
    "Vue",
    "Vue.js",
    "UI-Library",
    "Tailwind",
    "CSS",
    "Components",
    "Free"
  ],
  "author": {
    "email": "fabian@saali.info",
    "name": "saali"
  },
  "version": "1.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/sa-ui.umd.cjs",
  "module": "./dist/sa-ui.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sa-ui.js",
      "require": "./dist/sa-ui.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@storybook/vue3-vite": "^9.1.20",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "happy-dom": "^20.8.3",
    "postcss": "^8.5.6",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "lucide-vue-next": "^0.575.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "overrides": {
    "minimatch": ">=10.2.3"
  }
}
